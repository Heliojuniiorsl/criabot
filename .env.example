NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua-chave
# Necessário para o webhook dos bots ler configuração/token no servidor.
# Pegue em Supabase > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=
CRIABOT_OFFICIAL_TELEGRAM_BOT_TOKEN=
# Opcional em produção/túnel HTTPS: usado para registrar webhook do Telegram.
# Ex.: https://seu-dominio.com ou https://abc123.ngrok-free.app
CRIABOT_WEBHOOK_BASE_URL=
# Compatibilidade com projetos antigos:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon
