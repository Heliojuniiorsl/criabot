{
  "name": "criabot",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "local": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "local:unix": "bash scripts/start-local.sh",
    "local:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local.ps1",
    "local:stop:unix": "bash scripts/stop-local.sh",
    "on": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -Port 5050",
    "off": "powershell -ExecutionPolicy Bypass -File scripts/stop-local.ps1 -Port 5050",
    "build": "node --max-old-space-size=640 node_modules/vite/bin/vite.js build",
    "build:square": "node --max-old-space-size=640 node_modules/vite/bin/vite.js build",
    "build:dev": "vite build --mode development",
    "start": "node scripts/production-server.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
